# Copy this file to .env.local inside isolated_rss_codex_agent/
# and fill in values for your local or OpenAI-compatible model endpoint.

# Required for true skill mode:
OPENAI_API_KEY=your_api_key_here

# Examples:
# Local Ollama/OpenAI-compatible gateway:
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
#
# Local vLLM / LM Studio / other OpenAI-compatible server:
# OPENAI_BASE_URL=http://127.0.0.1:8000/v1
#
# Official OpenAI:
# OPENAI_BASE_URL=https://api.openai.com/v1

OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
